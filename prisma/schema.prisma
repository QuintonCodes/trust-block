generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Role Enum - Distinguishes between workers and clients
enum UserRole {
  WORKER
  CLIENT
}

// Users Table - Central directory using SIWE (Sign-In with Ethereum)
model User {
  walletAddress    String    @id @map("wallet_address")
  displayName      String?   @map("display_name")
  avatarUrl        String?   @map("avatar_url")
  bio              String?   @db.Text
  role             UserRole  @default(WORKER)
  createdAt        DateTime  @default(now()) @map("created_at")
  lastLogin        DateTime  @default(now()) @map("last_login")

  // Relations
  escrowsAsFreelancer EscrowLink[] @relation("FreelancerEscrows")
  escrowsAsClient     EscrowLink[] @relation("ClientEscrows")

  @@map("users")
}

// Escrow Status Enum
enum EscrowStatus {
  DRAFT
  AWAITING_FUNDS
  LOCKED
  IN_REVIEW
  RELEASED
  CANCELLED
  IN_DISPUTE
}

// Milestone Status Enum
enum MilestoneStatus {
  PENDING_FUNDS
  FUNDED
  WORK_SUBMITTED
  PENDING_APPROVAL      // Worker has submitted, waiting for client approval
  APPROVED_AND_PAID
  AUTO_RELEASED         // Released after 3 days of client inactivity
}

enum SubmissionType {
  LINK
  FILE
}

// Transaction Type Enum
enum TransactionType {
  DEPOSIT
  PAYOUT
  FEE_COLLECTION
  REFUND
}

// Escrow Links Table - Core of the application
model EscrowLink {
  id                String       @id @default(uuid())
  freelancerAddress String       @map("freelancer_address")
  clientAddress     String?      @map("client_address")
  projectTitle      String       @map("project_title")
  scopeOfWork       String       @map("scope_of_work") @db.Text
  totalAmount       Decimal      @map("total_amount") @db.Decimal(18, 6)
  currency          String       @default("USDC")
  status            EscrowStatus @default(DRAFT)
  contractAddress   String?      @map("contract_address")
  dueDate           DateTime?    @map("due_date")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relations
  freelancer   User          @relation("FreelancerEscrows", fields: [freelancerAddress], references: [walletAddress])
  client       User?         @relation("ClientEscrows", fields: [clientAddress], references: [walletAddress])
  milestones   Milestone[]
  transactions Transaction[]

  @@map("escrow_links")
}

// Milestones Table - Tracks individual payment phases
model Milestone {
  id             String          @id @default(uuid())
  escrowLinkId   String          @map("escrow_link_id")
  title          String
  description    String?         @db.Text
  amount         Decimal         @db.Decimal(18, 6)
  orderIndex     Int             @map("order_index")
  status         MilestoneStatus @default(PENDING_FUNDS)
  dueDate        DateTime?       @map("due_date")
  submittedAt    DateTime?       @map("submitted_at")    // When work was marked as complete
  autoReleaseAt  DateTime?       @map("auto_release_at") // 3 days after submission if client is silent

  submissionType SubmissionType? @map("submission_type")
  submissionUrl  String?         @map("submission_url")

  // Relations
  escrowLink EscrowLink @relation(fields: [escrowLinkId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

// Transactions Table - Cached index of on-chain events
model Transaction {
  id              String          @id @default(uuid())
  escrowLinkId    String          @map("escrow_link_id")
  txHash          String          @unique @map("tx_hash")
  transactionType TransactionType @map("transaction_type")
  fromAddress     String          @map("from_address")
  toAddress       String          @map("to_address")
  amount          Decimal         @db.Decimal(18, 6)
  timestamp       DateTime        @default(now())

  // Relations
  escrowLink EscrowLink @relation(fields: [escrowLinkId], references: [id], onDelete: Cascade)

  @@map("transactions")
}